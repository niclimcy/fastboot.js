{
    "name": "android-fastboot",
    "version": "1.1.3",
    "description": "JavaScript implementation of fastboot, using WebUSB",
    "main": "dist/fastboot.cjs",
    "repository": "https://github.com/kdrag0n/fastboot.js",
    "author": "Danny Lin <danny@kdrag0n.dev>",
    "license": "MIT",
    "dependencies": {
        "@zip.js/zip.js": "2.8.26"
    },
    "devDependencies": {
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/w3c-web-usb": "^1.0.14",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.2",
        "rollup": "^4.60.1",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2"
    },
    "scripts": {
        "doc": "typedoc src/index.ts",
        "build": "rollup -c && tsc"
    },
    "files": [
        "dist/*"
    ],
    "exports": {
        "types": "./dist/index.d.ts",
        "import": "./dist/fastboot.mjs",
        "require": "./dist/fastboot.cjs",
        "default": "./dist/fastboot.cjs"
    }
}
