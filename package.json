{
    "name": "@lineageos-infra/android-fastboot",
    "version": "1.1.5",
    "description": "JavaScript implementation of fastboot, using WebUSB",
    "main": "dist/fastboot.cjs",
    "module": "dist/fastboot.mjs",
    "types": "dist/fastboot.d.cts",
    "repository": "https://github.com/lineageos-infra/fastboot.js",
    "author": "Danny Lin <danny@kdrag0n.dev>",
    "license": "MIT",
    "dependencies": {
        "@zip.js/zip.js": "2.8.26"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/w3c-web-usb": "^1.0.14",
        "better-docs": "^2.7.3",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "prettier": "^3.8.4",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1"
    },
    "type": "module",
    "scripts": {
        "doc": "jsdoc -c jsdoc.json",
        "build": "tsdown",
        "lint": "eslint . --fix",
        "format": "prettier --write *.config.ts *.config.mjs src/",
        "type-check": "tsc --noEmit",
        "prepare": "husky"
    },
    "files": [
        "dist/*"
    ],
    "exports": {
        "import": {
            "types": "./dist/fastboot.d.mts",
            "default": "./dist/fastboot.mjs"
        },
        "require": {
            "types": "./dist/fastboot.d.cts",
            "default": "./dist/fastboot.cjs"
        }
    }
}
