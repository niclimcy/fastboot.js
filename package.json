{
    "name": "android-fastboot",
    "version": "1.1.3",
    "description": "JavaScript implementation of fastboot, using WebUSB",
    "main": "dist/fastboot.cjs",
    "repository": "https://github.com/kdrag0n/fastboot.js",
    "author": "Danny Lin <danny@kdrag0n.dev>",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "@zip.js/zip.js": "2.2.27"
    },
    "devDependencies": {
        "@types/w3c-web-usb": "^1.0.4",
        "better-docs": "^2.3.2",
        "eslint": "^7.18.0",
        "eslint-config-prettier": "^7.2.0",
        "prettier": "^2.2.1",
        "rolldown": "^1.0.0-rc.15",
        "typescript": "^6.0.2"
    },
    "scripts": {
        "doc": "jsdoc -c jsdoc.json",
        "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "rolldown -c && tsc -p tsconfig.build.json"
    },
    "files": [
        "dist/*"
    ],
    "exports": {
        "types": "./dist/index.d.ts",
        "import": "./dist/fastboot.mjs",
        "require": "./dist/fastboot.cjs",
        "default": "./dist/fastboot.cjs"
    }
}
